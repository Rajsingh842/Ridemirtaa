rules_version = '2';

// DEV-FRIENDLY RULES — tighten before production (validate fields & ownership).
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    match /rides/{rideId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.riderId == request.auth.uid;
      // Rider updates location; booking flow updates seats (transaction uses passenger auth)
      allow update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.riderId == request.auth.uid;
    }

    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /sos_alerts/{alertId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
  }
}
